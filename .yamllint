# SPDX-License-Identifier: MIT

extends: default

rules:
  braces:
    max-spaces-inside: 1
  comments-indentation: false
  line-length:
    max: 160
    level: warning
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  document-start: disable
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
  comments:
    min-spaces-from-content: 1

ignore: |
  .ansible/
  .cache/
  .molecule/
  .uv-cache/
  .venv/
